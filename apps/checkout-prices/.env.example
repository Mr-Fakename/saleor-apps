# ============================================================================
# Saleor API Configuration
# ============================================================================

# URL of Saleor GraphQL API
# Local development (Docker): http://api:8000/graphql/
# Local development (host): http://localhost:8000/graphql/
# Production: https://your-saleor-instance.com/graphql/
NEXT_PUBLIC_SALEOR_API_URL=http://localhost:8000/graphql/

# Slug of the channel to use for the app
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# ============================================================================
# App URL Configuration
# ============================================================================

# APP_API_BASE_URL: How Saleor (running in Docker) reaches this app
# - Docker: http://checkout-app:3001 (use service name)
# - Host: http://host.docker.internal:3001
# - Tunnel: https://your-tunnel-url.ngrok.io
# - Production: https://checkout-app.yourdomain.com
APP_API_BASE_URL=

# APP_IFRAME_BASE_URL: How Dashboard (browser) reaches this app
# - Local: http://localhost:3001
# - Tunnel: https://your-tunnel-url.ngrok.io
# - Production: https://checkout-app.yourdomain.com
APP_IFRAME_BASE_URL=

# ============================================================================
# APL (Auth Persistence Layer) Configuration
# ============================================================================

# APL type: 'file' for development, 'upstash' for production
APL=file

# Upstash Redis configuration (only needed if APL=upstash)
# Get these from https://upstash.com after creating a Redis database
# UPSTASH_URL=
# UPSTASH_TOKEN=

# ============================================================================
# Docker-specific Configuration (when running in Docker)
# ============================================================================

# Default channel for Docker deployment
DEFAULT_CHANNEL=default-channel

# Saleor API URL for Docker (use service name)
SALEOR_API_URL=http://api:8000/graphql/
