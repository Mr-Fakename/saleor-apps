# Docker Environment Variables Example
# Copy this file to .env.docker and fill in your values

# Core Configuration
SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# IMPORTANT: Pattern without slashes - SDK creates RegExp object
ALLOWED_DOMAIN_PATTERN=.*

# APL (Auth Persistence Layer)
# Options: file, dynamodb, saleor-cloud
APL=file

# DynamoDB Configuration
DYNAMODB_MAIN_TABLE_NAME=saleor-customer-extensions
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
INIT_DYNAMODB_ON_STARTUP=false

# Saleor API Configuration
SALEOR_API_URL=http://localhost:8000/graphql/

# Build-time variables (for Next.js public env vars)
NEXT_PUBLIC_SALEOR_API_URL=http://localhost:8000/graphql/
NEXT_PUBLIC_CUSTOMER_EXTENSIONS_APP_URL=http://localhost:3010

# Optional: Sentry Configuration
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional: OpenTelemetry
OTEL_SERVICE_NAME=customer-extensions
OTEL_EXPORTER_OTLP_ENDPOINT=
