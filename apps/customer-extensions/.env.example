# See src/lib/env.ts for exhaustive list of supported and required env variables

# Core Configuration
# The key used for encryption aes-256-cbc algorithm, which requires 16 or 32 bytes key in hex encoding.
# Use command `openssl rand -hex 32` to generate one
SECRET_KEY=

# Variable controlling Saleor domains that app can be installed on.
# It's a regex pattern.
ALLOWED_DOMAIN_PATTERN=/*/

# APL Configuration
# APL (Auth Persistence Layer) - tells app where to keep its credentials
# Options: file | upstash | dynamodb | saleor-cloud
APL=dynamodb

# Logging
# APP_LOG_LEVEL=info # one of "fatal" | "error" | "warn" | "info" | "debug" | "trace"

# Local Development
# When developed locally with Saleor inside docker, these can be set to:
# APP_IFRAME_BASE_URL = http://localhost:3010, so Dashboard on host can access iframe
# APP_API_BASE_URL=http://host.docker.internal:3010 - so Saleor can reach App running on host, from the container.
# If developed with tunnels, set this empty, it will fallback to default Next's localhost:3010
# https://docs.saleor.io/developer/extending/apps/local-app-development
# APP_IFRAME_BASE_URL=
# APP_API_BASE_URL=

# DynamoDB Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For local development with DynamoDB Local, uncomment:
# AWS_ENDPOINT_URL=http://localhost:8000
DYNAMODB_MAIN_TABLE_NAME=saleor-customer-extensions

# Automatically initialize DynamoDB tables on app startup (recommended for production)
# Set to "true" to enable automatic table creation when the app starts
INIT_DYNAMODB_ON_STARTUP=true

# Saleor API URL
SALEOR_API_URL=http://localhost:8000/graphql/

# Feature Toggles
# Require orders to be manually unlocked before customers can submit reviews
# Set to "true" to enable, "false" or leave unset for original behavior (purchase = can review)
REQUIRE_ORDER_UNLOCK_FOR_REVIEWS=false
