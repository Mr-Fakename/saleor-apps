# ==================== Customer Extensions App Configuration ====================
# Docker Image
CUSTOMER_EXTENSIONS_IMAGE=mrfakename/customer-extensions-app:latest

# Port Configuration
CUSTOMER_EXTENSIONS_PORT=3010

# Domain Configuration
CUSTOMER_EXTENSIONS_DOMAIN=saleor-customer-extension.vps.daybreakdevelopment.eu
CUSTOMER_EXTENSIONS_PUBLIC_URL=https://saleor-customer-extension.vps.daybreakdevelopment.eu/
CUSTOMER_EXTENSIONS_SITE_DOMAIN=saleor-customer-extension.vps.daybreakdevelopment.eu
CUSTOMER_EXTENSIONS_APP_IFRAME_BASE_URL=https://saleor-customer-extension.vps.daybreakdevelopment.eu
CUSTOMER_EXTENSIONS_APP_API_BASE_URL=https://saleor-customer-extension.vps.daybreakdevelopment.eu

# Build-time Public URLs (for Next.js)
CUSTOMER_EXTENSIONS_NEXT_PUBLIC_SALEOR_API_URL=https://api.vps.daybreakdevelopment.eu/graphql/
CUSTOMER_EXTENSIONS_NEXT_PUBLIC_APP_URL=https://saleor-customer-extension.vps.daybreakdevelopment.eu

# App Storage (DynamoDB APL)
CUSTOMER_EXTENSIONS_APL=dynamodb
CUSTOMER_EXTENSIONS_DYNAMODB_TABLE=customer-extensions-main-table
CUSTOMER_EXTENSIONS_INIT_DYNAMODB=true

# Security & Encryption
CUSTOMER_EXTENSIONS_SECRET_KEY=c1d2e3f4g5h6i7j8k9l0m1n2o3p4q5r6s7t8u9v0w1x2y3z4a5b6c7d8e9f0g1h2

# Domain Pattern (regex without slashes - SDK will create RegExp object)
# For production, restrict to your specific domain:
# CUSTOMER_EXTENSIONS_ALLOWED_DOMAIN_PATTERN=^https://.*\.vps\.daybreakdevelopment\.eu$
# For development/testing, allow all:
CUSTOMER_EXTENSIONS_ALLOWED_DOMAIN_PATTERN=.*

# CORS Configuration
CUSTOMER_EXTENSIONS_CORS_ALLOW_ORIGIN_REGEX=.*

# Traefik Configuration
CUSTOMER_EXTENSIONS_PRIORITY=100
CUSTOMER_EXTENSIONS_FLUSH_INTERVAL=1ms
CUSTOMER_EXTENSIONS_MAX_REQUEST_BODY_BYTES=10485760
CUSTOMER_EXTENSIONS_RETRY_EXPRESSION=IsNetworkError() && Attempts() <= 2

# ==================== Shared Configuration ====================
# These variables are shared across all Saleor apps

# AWS Configuration (for DynamoDB)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Saleor API Configuration
SALEOR_API_URL=https://api.vps.daybreakdevelopment.eu/graphql/

# CORS Configuration (Shared)
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,saleor-api-url
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400
CORS_ADD_VARY_HEADER=true

# Forwarded Headers
FORWARDED_PROTO=https
FORWARDED_PORT=443

# Optional: Sentry Configuration
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional: OpenTelemetry
OTEL_SERVICE_NAME=customer-extensions-prod
OTEL_EXPORTER_OTLP_ENDPOINT=
