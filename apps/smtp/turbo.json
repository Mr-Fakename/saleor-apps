{
  "$schema": "https://turbo.build/schema.v2.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "EMAIL_BRIDGE_API_SECRET",
        "EMAIL_BRIDGE_SMTP_HOST",
        "EMAIL_BRIDGE_SMTP_PORT",
        "EMAIL_BRIDGE_SMTP_SECURE",
        "EMAIL_BRIDGE_SMTP_USER",
        "EMAIL_BRIDGE_SMTP_PASS",
        "EMAIL_BRIDGE_SMTP_FROM",
        "INIT_DYNAMODB_ON_STARTUP"
      ]
    },
    "deploy": {
      "env": [
        "ALLOWED_DOMAIN_PATTERN",
        "APL",
        "APP_API_BASE_URL",
        "APP_IFRAME_BASE_URL",
        "DIGITAL_DOWNLOADS_APP_URL",
        "NEXT_PUBLIC_SENTRY_DSN",
        "REST_APL_ENDPOINT",
        "REST_APL_TOKEN",
        "SECRET_KEY",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_PROJECT",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "DYNAMODB_MAIN_TABLE_NAME"
      ]
    }
  }
}
