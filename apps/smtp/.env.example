# The key used for metadata encryption. Required for production builds
SECRET_KEY=

# APL Config
# https://docs.saleor.io/developer/extending/apps/developing-apps/app-sdk/apl
APL=
REST_APL_ENDPOINT=
REST_APL_TOKEN=

APP_LOG_LEVEL=info

# Variable controlling Saleor domains that app can be installed on.
# It's a regex pattern.
ALLOWED_DOMAIN_PATTERN=/*/

# Local development variables. When developed locally with Saleor inside docker, these can be set to:
# APP_IFRAME_BASE_URL = http://localhost:3000, so Dashboard on host can access iframe
# APP_API_BASE_URL=http://host.docker.internal:3000 - so Saleor can reach App running on host, from the container.
# If developed with tunnels, set this empty, it will fallback to default Next's localhost:3000
# https://docs.saleor.io/developer/extending/apps/local-app-development
# APP_IFRAME_BASE_URL=
# APP_API_BASE_URL=

# OTEL related variables
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=saleor-app-smtp
# OTEL_LOG_LEVEL=info, # one of error, warn, info, debug, verbose, all or none
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 # OTEL collector endpoint (http protocol)
# OTEL_ACCESS_TOKEN=token # token used to authenticate with OTEL collector
# NEXT_RUNTIME=nodejs

# Digital Downloads Integration
# DynamoDB table name where download tokens are stored (shared with digital-downloads app)
DYNAMODB_MAIN_TABLE_NAME=
# Base URL of the digital-downloads app for constructing download URLs
DIGITAL_DOWNLOADS_APP_URL=https://digital-downloads.example.com

# On-demand order CSV export (/api/export-orders)
# Secret for the private export URL/header. Pass as ?key=... or X-API-Key header.
ORDER_EXPORT_API_KEY=
# Postgres connection string to the Saleor DB (same DB the cron export reads).
# In the compose network this is the `db` service, e.g.:
# ORDER_EXPORT_DATABASE_URL=postgres://saleor:<password>@db:5432/saleor
ORDER_EXPORT_DATABASE_URL=
# Default recipient for the export email (overridable per request via ?to=).
ORDER_EXPORT_RECIPIENT=
# SMTP relay for the export email. SET THESE to a REAL relay (the prod
# EMAIL_BRIDGE_SMTP_* points at mailpit:1025 = caught, not delivered). Mirror the
# cron script's relay, e.g. smtp.porkbun.com / 587 / contact@dess-equipement.com.
ORDER_EXPORT_SMTP_HOST=
ORDER_EXPORT_SMTP_PORT=587
ORDER_EXPORT_SMTP_SECURE=false
ORDER_EXPORT_SMTP_USER=
ORDER_EXPORT_SMTP_PASS=
ORDER_EXPORT_SMTP_FROM=
