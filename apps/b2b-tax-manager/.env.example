# APL type: file (dev), upstash, saleor-cloud
APL=file

# API key for /api/validate-vat endpoint
B2B_TAX_MANAGER_API_KEY=change-me-in-production

# Seller VAT number (FR format) for reverse charge invoices
SELLER_VAT_NUMBER=FR12345678901

# Allowed Saleor domains (regex pattern)
ALLOWED_DOMAIN_PATTERN=

# App URLs (override for tunnels/proxies)
APP_IFRAME_BASE_URL=
APP_API_BASE_URL=
